# Share only the distributable StatCheck plugin.
*

# Keep repository metadata.
!.gitignore
!.gitattributes

# Allow the plugin folder path.
!Plugins/
Plugins/*
!Plugins/StatCheck/
Plugins/StatCheck/*

# Allow only files needed by another Unreal project.
!Plugins/StatCheck/StatCheck.uplugin
!Plugins/StatCheck/사용설명.md
!Plugins/StatCheck/Source/
!Plugins/StatCheck/Source/**
!Plugins/StatCheck/Resources/
Plugins/StatCheck/Resources/*
!Plugins/StatCheck/Resources/Icon128.png

# Never share generated plugin outputs.
Plugins/StatCheck/Binaries/
Plugins/StatCheck/Intermediate/
Plugins/StatCheck/Saved/
Plugins/StatCheck/DerivedDataCache/
Plugins/StatCheck/Content/

# Ignore common generated/editor files even if rules change later.
.idea/
.vs/
*.sln
*.suo
*.VC.db
*.VC.opendb
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
